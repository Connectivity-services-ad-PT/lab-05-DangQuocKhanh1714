              }
            ],
            "url": {
              "raw": "{{baseUrl}}/policies/access/INVALID_POLICY",
              "host": ["{{baseUrl}}"],
              "path": ["policies", "access", "INVALID_POLICY"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 404\", function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04_Boundary_Reliability",
      "item": [
        {
          "name": "Long cardId - Test boundary (51 chars should fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardId\": \"CARD_AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA\",\n  \"gateId\": \"GATE_A01\",\n  \"timestamp\": \"2026-06-03T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/access/check",
              "host": ["{{baseUrl}}"],
              "path": ["access", "check"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 422 for boundary violation\", function () {",
                  "  pm.response.to.have.status(422);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05_Consumer_side_Smoke",
      "item": [
        {
          "name": "Call AI Vision Mock - Smoke Test",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"imageRef\": \"test-frame-001.jpg\"\n}"
            },
            "url": {
              "raw": "{{aiVisionMockUrl}}/detect",
              "host": ["{{aiVisionMockUrl}}"],
              "path": ["detect"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "06_Local_only_NonFunctional",
      "item": [
        {
          "name": "Response Time Under 500ms - Health Check",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.environment.get(\"env\") === \"local\") {",
                  "  pm.test(\"Response time is below 500ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "  });",
                  "} else {",
                  "  pm.test(\"Latency test skipped on mock\", function () {",
                  "    pm.expect(true).to.be.true;",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "authToken",
      "value": "test-token"
    },
    {
      "key": "aiVisionMockUrl",
      "value": "http://localhost:4011"
    }
  ]
