                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardId\": \"\",\n  \"gateId\": \"GATE_A01\",\n  \"timestamp\": \"2026-06-03T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/access/check",
              "host": ["{{baseUrl}}"],
              "path": ["access", "check"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 422\", function () {",
                  "  pm.response.to.have.status(422);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Policy Not Found - Should return 404",
          "request": {
            "method": "GET",
